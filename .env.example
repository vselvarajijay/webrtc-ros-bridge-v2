# Copy to .env and fill in. .env is gitignored; do not commit secrets.
# These are used when starting the container shell (cli.sh start) and can be
# passed to scout_robot_bridge as parameters.

# --- LangGraph chat agent (connectx_langgraph) ---
# OpenAI API key for the LangGraph chat agent.
OPENAI_API_KEY=
# LangSmith (tracing and LangGraph Studio). Get an API key at https://smith.langchain.com/
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
# LangSmith project name for grouping traces (e.g. "robot").
LANGSMITH_PROJECT=robot
# OpenAI model to use (default: gpt-4o-mini).
# LLM_MODEL=gpt-4o-mini
# MCP server URL (default: http://connectx_mcp:8002/mcp — the Docker service name).
# Override only if running the MCP server outside Docker.
# MCP_SERVER_URL=http://connectx_mcp:8002/mcp

# Selects which robot SDK to use (e.g. earth_rovers_sdk). Default: earth_rovers_sdk.
ROBOT_TYPE=earth_rovers_sdk

# Earth Rovers (FrodoBot) SDK container: built from https://github.com/frodobots-org/earth-rovers-sdk.
# The scout_sdk service uses env from .env.frodobots (SDK_API_TOKEN, BOT_SLUG, etc.) — no FRODOBOT_ prefix there.
# Create .env.frodobots with those SDK-native names (see Frodobots docs). .env.frodobots is gitignored.
# Earth Rovers SDK base URL. With Docker Compose, scout_bridge uses http://scout_sdk:8001 by default.
# Override if you run the SDK elsewhere (e.g. host: SDK_LOCAL_URL=http://127.0.0.1:8001).
# SDK_LOCAL_URL=http://scout_sdk:8001

# WebRTC ICE: STUN + optional TURN. With Docker, scout_turn runs coturn; use these so browser and webrtc node connect.
# STUN_URL=stun:stun.l.google.com:19302
# TURN_URL=turn:localhost:3478
# TURN_USERNAME=scout
# TURN_CREDENTIAL=scout
# (scout_webrtc uses turn:host.docker.internal:3478 via TURN_URL_NODE in docker-compose; no need to set in .env)

# Bridge/ROS params (FRODOBOT_*). The scout_sdk container uses .env.frodobots with SDK names (SDK_API_TOKEN, BOT_SLUG, etc.).
FRODOBOT_SDK_API_TOKEN=
FRODOBOT_BOT_SLUG=
# If the robot moves backward but not forward, set EARTH_ROVERS_LINEAR_SIGN=-1 (bridge negates linear when sending via RTM).
# EARTH_ROVERS_LINEAR_SIGN=-1
# Chrome for front camera. Bridge image uses /usr/bin/google-chrome; override here if needed.
FRODOBOT_CHROME_EXECUTABLE_PATH=
FRODOBOT_MAP_ZOOM_LEVEL=18
FRODOBOT_MISSION_SLUG=
# Front camera capture size (smaller = faster, less bandwidth). Default 3840x2160.
# FRODOBOT_VIEWPORT_WIDTH=1280
# FRODOBOT_VIEWPORT_HEIGHT=720

# Earth Rovers SDK (scout_sdk): when 1, /data and /v2/front skip the headless browser (no join, no timeouts).
# Default in docker-compose is 1: /v2/front returns a placeholder frame so you see "No camera feed" in the video area.
# For live front camera: set SDK_SKIP_BROWSER_JOIN=0 and configure .env.frodobots so the SDK browser can join and serve /v2/front.
# SDK_SKIP_BROWSER_JOIN=0

# Video: IMAGE_FORMAT=jpeg, IMAGE_QUALITY (0–1). Viewport above sets capture resolution for lower latency.

# Frame pipeline metrics: one log line per camera frame with timing for each stage (SDK capture, bridge fetch, decode, resize).
# Log file is written in workspace root by default. Set to 0 to disable.
# FRAME_METRICS_ENABLED=1
# FRAME_METRICS_LOG=frame_metrics.log
