#!/usr/bin/env python3

"""
Overlay recorder node: subscribe to /camera/image_raw and /navigation_state,
draw the nav state log in the bottom-right of each frame, and write a new video file.
"""

import atexit
import os
import signal
import sys

import rclpy
from rclpy.node import Node
from rclpy.qos import QoSProfile, ReliabilityPolicy, HistoryPolicy, DurabilityPolicy
from sensor_msgs.msg import Image
from optical_flow_nav.msg import NavigationState
from cv_bridge import CvBridge
import cv2

# Match test_video_publisher_node / optical_flow_node (BEST_EFFORT, KEEP_LAST)
SENSOR_QOS = QoSProfile(
    reliability=ReliabilityPolicy.BEST_EFFORT,
    history=HistoryPolicy.KEEP_LAST,
    depth=10,
    durability=DurabilityPolicy.VOLATILE,
)

# Text overlay: small font for details, large for turn directive
FONT = cv2.FONT_HERSHEY_SIMPLEX
FONT_SCALE = 0.4
LINE_HEIGHT = 16
MARGIN = 12
PADDING = 4

# Prominent turn banner (top-center)
TURN_FONT = cv2.FONT_HERSHEY_SIMPLEX
TURN_FONT_SCALE = 1.4
TURN_FONT_THICKNESS = 3
CONFIDENCE_FONT_SCALE = 0.9
CONFIDENCE_FONT_THICKNESS = 2
BANNER_PADDING = 20
BANNER_MARGIN_TOP = 24


def _turn_label(safest_turn):
    """Convert safest_turn int8 to clear label. -1=left, 0=forward, 1=right."""
    if safest_turn < 0:
        return "TURN LEFT"
    if safest_turn > 0:
        return "TURN RIGHT"
    return "GO FORWARD"


def _turn_banner_color(safest_turn):
    """BGR color for banner: green forward, blue left, orange right."""
    if safest_turn < 0:
        return (200, 120, 0)   # blue-ish (left)
    if safest_turn > 0:
        return (0, 120, 255)  # orange (right)
    return (0, 180, 0)        # green (forward)


def _format_nav_state(state):
    """Format NavigationState as multi-line string (echo style)."""
    if state is None:
        return "waiting for /navigation_state..."
    return (
        "forward_safe: %s\n"
        "forward_risk: %s\n"
        "safest_turn: %s\n"
        "turn_confidence: %s\n"
        "urgency_score: %s\n"
        "confidence: %s\n"
        "flow_mag_left: %s\n"
        "flow_mag_center: %s\n"
        "flow_mag_right: %s"
        % (
            state.forward_safe,
            state.forward_risk,
            state.safest_turn,
            state.turn_confidence,
            state.urgency_score,
            state.confidence,
            state.flow_mag_left,
            state.flow_mag_center,
            state.flow_mag_right,
        )
    )


def _derive_overlay_path(video_path):
    """Derive overlay output path from video_path: insert _overlay before extension."""
    base, ext = os.path.splitext(video_path)
    return base + "_overlay" + (ext if ext else ".mp4")


class VideoOverlayRecorderNode(Node):
    def __init__(self):
        super().__init__("video_overlay_recorder_node")
        self.declare_parameter("video_path", "")
        self.declare_parameter("overlay_output_path", "")
        self.declare_parameter("fps", 10.0)
        self.declare_parameter("stream_end_timeout", 1.5)

        video_path = self.get_parameter("video_path").get_parameter_value().string_value
        overlay_output_path = (
            self.get_parameter("overlay_output_path").get_parameter_value().string_value
        )
        if not overlay_output_path and video_path:
            overlay_output_path = _derive_overlay_path(video_path)
        if not overlay_output_path:
            overlay_output_path = os.path.abspath("optical_flow_overlay.mp4")

        self._overlay_output_path = overlay_output_path
        self._fps = self.get_parameter("fps").get_parameter_value().double_value
        self._stream_end_timeout = self.get_parameter("stream_end_timeout").get_parameter_value().double_value
        self._writer = None
        self._latest_nav_state = None
        self._last_image_time = None
        self._shutting_down = False
        self._bridge = CvBridge()

        self._image_sub = self.create_subscription(
            Image,
            "/camera/image_raw",
            self._on_image,
            SENSOR_QOS,
        )
        self._nav_sub = self.create_subscription(
            NavigationState,
            "/navigation_state",
            self._on_nav_state,
            10,
        )

        self._stream_end_timer = self.create_timer(0.5, self._check_stream_ended)

        self.get_logger().info(
            "Recording overlay video to %s at %.1f fps" % (self._overlay_output_path, self._fps)
        )

    def _on_nav_state(self, msg):
        self._latest_nav_state = msg

    def _check_stream_ended(self):
        """If no image for stream_end_timeout and we have a writer, close file and exit voluntarily."""
        if self._shutting_down or self._writer is None or self._last_image_time is None:
            return
        now = self.get_clock().now()
        elapsed = (now - self._last_image_time).nanoseconds / 1e9
        if elapsed >= self._stream_end_timeout:
            self._shutting_down = True
            self.get_logger().info("No frames for %.1fs; closing overlay video." % elapsed)
            self._release_writer()
            os._exit(0)

    def _on_image(self, msg):
        self._last_image_time = self.get_clock().now()
        try:
            frame = self._bridge.imgmsg_to_cv2(msg, desired_encoding="bgr8")
        except Exception as e:
            self.get_logger().warn("cv_bridge conversion failed: %s" % e)
            return

        h, w = frame.shape[:2]
        if self._writer is None:
            fourcc = cv2.VideoWriter_fourcc(*"mp4v")
            self._writer = cv2.VideoWriter(
                self._overlay_output_path, fourcc, self._fps, (w, h)
            )
            if not self._writer.isOpened():
                self.get_logger().error("Failed to open VideoWriter: %s" % self._overlay_output_path)
                self._writer = None
                return

        state = self._latest_nav_state

        # --- Prominent turn + confidence banner (top-center) ---
        if state is not None:
            turn_str = _turn_label(state.safest_turn)
            conf_pct = int(round(state.turn_confidence * 100))
            confidence_str = "Confidence: %d%%" % conf_pct

            (tw1, th1), _ = cv2.getTextSize(turn_str, TURN_FONT, TURN_FONT_SCALE, TURN_FONT_THICKNESS)
            (tw2, th2), _ = cv2.getTextSize(confidence_str, TURN_FONT, CONFIDENCE_FONT_SCALE, CONFIDENCE_FONT_THICKNESS)
            banner_w = max(tw1, tw2) + 2 * BANNER_PADDING
            banner_h = th1 + th2 + 3 * BANNER_PADDING
            bx = (w - banner_w) // 2
            by = BANNER_MARGIN_TOP

            # Banner background (semi-transparent)
            overlay = frame.copy()
            color = _turn_banner_color(state.safest_turn)
            cv2.rectangle(overlay, (bx, by), (bx + banner_w, by + banner_h), (40, 40, 40), -1)
            cv2.rectangle(overlay, (bx, by), (bx + banner_w, by + banner_h), color, 3)
            cv2.addWeighted(overlay, 0.6, frame, 0.4, 0, frame)

            # Turn direction (large, white)
            tx = bx + (banner_w - tw1) // 2
            ty = by + BANNER_PADDING + th1
            cv2.putText(frame, turn_str, (tx, ty), TURN_FONT, TURN_FONT_SCALE, (255, 255, 255), TURN_FONT_THICKNESS)
            # Confidence below
            cx = bx + (banner_w - tw2) // 2
            cy = ty + BANNER_PADDING + th2
            cv2.putText(frame, confidence_str, (cx, cy), TURN_FONT, CONFIDENCE_FONT_SCALE, (255, 255, 255), CONFIDENCE_FONT_THICKNESS)

        # --- Detail block (bottom-right) ---
        text = _format_nav_state(state)
        lines = text.strip().split("\n")

        # Measure text block
        max_w = 0
        total_h = 0
        for line in lines:
            (tw, th), _ = cv2.getTextSize(line, FONT, FONT_SCALE, 1)
            max_w = max(max_w, tw)
            total_h += th + (LINE_HEIGHT - th)  # use fixed line height

        box_w = max_w + 2 * PADDING
        box_h = len(lines) * LINE_HEIGHT + 2 * PADDING
        x0 = w - MARGIN - box_w
        y0 = h - MARGIN - box_h

        # Semi-transparent black background
        overlay = frame.copy()
        cv2.rectangle(overlay, (x0, y0), (x0 + box_w, y0 + box_h), (0, 0, 0), -1)
        cv2.addWeighted(overlay, 0.5, frame, 0.5, 0, frame)

        # Draw text (white)
        for i, line in enumerate(lines):
            y = y0 + PADDING + (i + 1) * LINE_HEIGHT - 4
            cv2.putText(
                frame, line, (x0 + PADDING, y), FONT, FONT_SCALE, (255, 255, 255), 1
            )

        self._writer.write(frame)

    def _release_writer(self):
        """Release VideoWriter so the mp4 is properly finalized. Idempotent."""
        if self._writer is not None:
            self._writer.release()
            self._writer = None
            self.get_logger().info("Overlay video saved: %s" % self._overlay_output_path)

    def destroy_node(self, *args, **kwargs):
        self._release_writer()
        super().destroy_node(*args, **kwargs)


# Module-level ref so signal/atexit handlers can release the writer when launch kills the process.
_overlay_node = None


def _shutdown_handler(*_):
    """On SIGTERM/SIGINT: release writer so mp4 is valid, then request shutdown."""
    global _overlay_node
    if _overlay_node is not None:
        _overlay_node._release_writer()
    try:
        rclpy.shutdown()
    except Exception:
        pass


def main(args=None):
    global _overlay_node
    rclpy.init(args=args)
    node = VideoOverlayRecorderNode()
    _overlay_node = node

    signal.signal(signal.SIGTERM, _shutdown_handler)
    signal.signal(signal.SIGINT, _shutdown_handler)

    def _atexit_release():
        if _overlay_node is not None:
            _overlay_node._release_writer()

    atexit.register(_atexit_release)

    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    finally:
        atexit.unregister(_atexit_release)
        node.destroy_node()
        rclpy.shutdown()


if __name__ == "__main__":
    main()
