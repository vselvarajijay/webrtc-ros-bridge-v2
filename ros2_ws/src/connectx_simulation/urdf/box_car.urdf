<?xml version="1.0"?>
<robot name="box_car">

  <link name="chassis">
    <visual>
      <geometry><box size="0.5 0.3 0.1"/></geometry>
      <material name="blue"><color rgba="0.2 0.5 0.8 1"/></material>
    </visual>
    <collision>
      <geometry><box size="0.5 0.3 0.1"/></geometry>
    </collision>
  </link>

  <link name="wheel_fl">
    <visual>
      <geometry><cylinder radius="0.1" length="0.05"/></geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.1" length="0.05"/></geometry>
    </collision>
  </link>
  <joint name="joint_wheel_fl" type="continuous">
    <parent link="chassis"/><child link="wheel_fl"/>
    <origin xyz="0.2 0.175 0" rpy="-1.5707 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="wheel_fr">
    <visual>
      <geometry><cylinder radius="0.1" length="0.05"/></geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.1" length="0.05"/></geometry>
    </collision>
  </link>
  <joint name="joint_wheel_fr" type="continuous">
    <parent link="chassis"/><child link="wheel_fr"/>
    <origin xyz="0.2 -0.175 0" rpy="-1.5707 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="wheel_rl">
    <visual>
      <geometry><cylinder radius="0.1" length="0.05"/></geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.1" length="0.05"/></geometry>
    </collision>
  </link>
  <joint name="joint_wheel_rl" type="continuous">
    <parent link="chassis"/><child link="wheel_rl"/>
    <origin xyz="-0.2 0.175 0" rpy="-1.5707 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="wheel_rr">
    <visual>
      <geometry><cylinder radius="0.1" length="0.05"/></geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.1" length="0.05"/></geometry>
    </collision>
  </link>
  <joint name="joint_wheel_rr" type="continuous">
    <parent link="chassis"/><child link="wheel_rr"/>
    <origin xyz="-0.2 -0.175 0" rpy="-1.5707 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

</robot>
